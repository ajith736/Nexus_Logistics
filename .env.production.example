PORT=5000
NODE_ENV=production

MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/nexus_logistics?retryWrites=true&w=majority

JWT_SECRET=replace_with_very_strong_secret
JWT_REFRESH_SECRET=replace_with_very_strong_refresh_secret

REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

STORAGE_PROVIDER=s3
AWS_REGION=ap-south-1
S3_BUCKET=nexus-logistics-uploads-prod-yourname
S3_UPLOAD_PREFIX=uploads
S3_ERROR_PREFIX=errors
S3_SIGNED_URL_TTL_SECONDS=900

MAILTRAP_API_TOKEN=
MAIL_FROM=hello@demomailtrap.co
MAIL_FROM_NAME=Nexus Logistics
MAILTRAP_CATEGORY=Upload Report

# SMTP fallback when MAILTRAP_API_TOKEN is not set
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=

SUPERADMIN_EMAIL=superadmin@nexus.io
SUPERADMIN_PASSWORD=replace_with_strong_password

CLIENT_URL=https://your-frontend-domain.com
PUBLIC_API_URL=https://your-api-domain.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com
