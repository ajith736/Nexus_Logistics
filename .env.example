PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/nexus_logistics?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_strong_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret

# Redis
REDIS_ENABLED=true
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# File storage: local or s3
STORAGE_PROVIDER=local
AWS_REGION=ap-south-1
S3_BUCKET=
S3_UPLOAD_PREFIX=uploads
S3_ERROR_PREFIX=errors
S3_SIGNED_URL_TTL_SECONDS=900

# Mail (SMTP fallback)
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=replace_with_mail_user
MAIL_PASS=replace_with_mail_pass

# Mailtrap API (preferred when token is set)
MAILTRAP_API_TOKEN=
MAIL_FROM=hello@demomailtrap.co
MAIL_FROM_NAME=Nexus Logistics
MAILTRAP_CATEGORY=Upload Report

# Seed superadmin
SUPERADMIN_EMAIL=superadmin@nexus.io
SUPERADMIN_PASSWORD=replace_with_strong_password

# Frontend + public URLs
CLIENT_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:5000

# CORS (comma-separated list). Leave empty to use CLIENT_URL only.
CORS_ALLOWED_ORIGINS=
